# ──────────────────────────────────────────────────────────────────────────────
# Rediscover Travel — Environment Variables
# ──────────────────────────────────────────────────────────────────────────────
# Copy this file to .env.local for local dev (never commit .env.local).
# In production, add these in:
#   Cloudflare Pages → your project → Settings → Environment Variables
# ──────────────────────────────────────────────────────────────────────────────

# Your Resend secret key — get one at https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# The inbox that receives booking enquiries
TO_EMAIL=vinesh@rediscovertravel.com

# Verified "from" address (domain must be verified in Resend → Domains)
# Format:  Display Name <address@yourdomain.com>
FROM_EMAIL=Rediscover Travel <enquiries@rediscovertravel.com>
